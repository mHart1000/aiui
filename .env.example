# Database Configuration
PGUSER=aiui_user
PGPASSWORD=password
PGHOST=127.0.0.1
PGPORT=5432

# OpenAI Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_ENABLED=true
DEFAULT_MODEL=gpt-4o-2024-08-06

# Application Configuration
PORT=3100
FRONTEND_URL=http://localhost:9100
RAILS_ENV=development

# Devise JWT Secret Key (generate with: rails secret)
DEVISE_JWT_SECRET_KEY=your-secret-key-here

WHISPER_SERVER_URL=http://127.0.0.1:8878

# TTS Configuration (TTS_ADAPTER: kokoro | qwen3 | chatterbox)
TTS_ADAPTER=kokoro
KOKORO_TTS_URL=http://localhost:8880
# qwen3 = faster-qwen3-tts openai_server on 8881 (cloning; no voices endpoint)
QWEN3_TTS_URL=http://localhost:8881
# Voice names matching the server's voices.json keys (no voices endpoint to query)
QWEN3_TTS_VOICES=aiden
CHATTERBOX_TTS_URL=http://localhost:8004
