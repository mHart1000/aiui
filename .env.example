# Database Configuration
PGUSER=aiui_user
PGPASSWORD=password
PGHOST=127.0.0.1
PGPORT=5432

# OpenAI Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_ENABLED=true
DEFAULT_MODEL=gpt-4o-2024-08-06

# Application Configuration
PORT=3100
FRONTEND_URL=http://localhost:9100
RAILS_ENV=development

# Devise JWT Secret Key (generate with: rails secret)
DEVISE_JWT_SECRET_KEY=your-secret-key-here

# Whisper (speech-to-text). Build whisper.cpp separately; see README "STT setup (Whisper)".
# WHISPER_CLI_PATH=/home/you/whisper/build/bin/whisper-cli
# WHISPER_MODEL_PATH=/home/you/whisper/models/ggml-small.en.bin
